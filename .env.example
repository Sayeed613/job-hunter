# ═══════════════════════════════════════════════════════════
# JOB AUTOMATION BOT — Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── OpenAI / OpenRouter ─────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Telegram ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Firebase ────────────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=./secrets/firebase.json
FIREBASE_PROJECT_ID=

# ── LinkedIn (for browser automation) ──────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# ── Job Search / Filtering ─────────────────────────────────
JOB_KEYWORDS=React,Next.js,Python,FastAPI,Node.js,TypeScript,Full-Stack,Backend,Laravel,PHP
LOCATIONS=Bangalore,Remote India,Remote Global,Hybrid Bangalore
EXCLUDED_COMPANIES=
MIN_EXPERIENCE=0
MAX_EXPERIENCE=6
RUN_INTERVAL_HOURS=2
MAX_APPLICATIONS_PER_CYCLE=15

# ── Browser ────────────────────────────────────────────────
HEADLESS=true

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
